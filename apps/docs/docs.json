{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Blue Agent",
  "theme": "mint",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#4FC3F7",
    "light": "#4FC3F7",
    "dark": "#29ABE2"
  },
  "topbarLinks": [
    {
      "name": "blueagent.dev",
      "url": "https://blueagent.dev"
    }
  ],
  "topbarCtaButton": {
    "name": "Open Console",
    "url": "https://blueagent.dev/console"
  },
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/madebyshun/blue-agent"
    },
    {
      "name": "X / Twitter",
      "icon": "x-twitter",
      "url": "https://x.com/blocky_agent"
    },
    {
      "name": "Telegram",
      "icon": "telegram",
      "url": "https://t.me/blueagent_hub"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "installation"]
          },
          {
            "group": "Skills",
            "pages": ["skills/overview", "skills/mcp"]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/workflow",
              "cli/setup",
              "cli/chat",
              "cli/score",
              "cli/discovery",
              "cli/launch",
              "cli/tasks",
              "cli/microtasks",
              "cli/tui"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": ["api/overview", "api/console", "api/chat", "api/x402"]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "x-twitter": "https://x.com/blocky_agent",
    "github": "https://github.com/madebyshun/blue-agent"
  }
}
